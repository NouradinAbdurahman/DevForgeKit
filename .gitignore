# OS files
.DS_Store
Thumbs.db
desktop.ini

# Generated reports (machine-specific, regenerate with scripts/report.sh
# and scripts/inventory.sh)
reports/*.txt
reports/*.md

# macOS preference backups (scripts/preferences.sh) - personal desktop
# settings, kept local by default; remove this line if you want to version them
preferences/*.plist

# Config backups created by scripts/common.sh's fs_safe_copy
*.backup-*

# Local default-profile selection (./dev profile use <name>) - machine-specific
.devprofile

# Local secrets - never commit real values, only .env.example
.env
.env.local

# Terraform local state (templates/terraform and any project using that template)
.terraform/
*.tfstate
*.tfstate.backup

# DevForgeKit Core CLI (cli/) - installed by bootstrap.sh's
# ensure_cli_dependencies, reproducible from cli/package-lock.json
cli/node_modules/

# Marker written by the `devforgekit` dispatcher's self_heal_cli_deps()
# when a just-in-time `npm install` in cli/ fails, so it doesn't retry
# on every command - machine-local, never meant to be committed
cli/.npm-install-failed
